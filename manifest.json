{
  "manifest_version": 3,
  "name": "JobForm AutoFill",
  "version": "1.0.0",
  "description": "Auto-fill job application forms easily.",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "AutoFill Form"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jobform-autofill@example.com",
      "strict_min_version": "109.0"
    }
  }
}